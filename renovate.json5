{
  // Frankenbot — Renovate configuration.
  //
  // Role in the platform: Renovate is the DETERMINISTIC RADAR only. It contributes
  // detection (its datasources), dedup/state, and scheduling — NO reasoning. The
  // Frankenbot agent fleet (later phases) reasons on top of every PR (changelog,
  // risk tier, migration). See ~/.claude/plans/thoughts-on-a-project-validated-nova.md.
  //
  // MVP scope (Phase 1) was THREE high-density, natively-managed surfaces only —
  // GitHub Action pins, pre-commit revs, Dockerfile bases.
  //
  // PHASE 5 (this config) BROADENS the radar for the post-MVP multi-repo fan-out:
  // terraform, helm, and nuget/dotnet managers are enabled, plus customManagers
  // for mise tool pins and paket. EVERYTHING here remains PROPOSE-ONLY and
  // human-gated: NO auto-merge is configured. Merges stay human (MVP) until the
  // agent's risk-tier engine + the autonomy flag (FRANKENBOT_AUTONOMY_ENABLED,
  // default false) are enabled in a later phase. The low prConcurrentLimit /
  // prHourlyLimit below deliberately throttle the first fan-out flood.
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: [
    "config:recommended",
    ":semanticCommits", // repo uses Conventional Commits → PRs land as chore(deps): ...
    "helpers:pinGitHubActionDigests", // reproduces the repo's `@<sha> # vX.Y.Z` action-pin style
  ],

  // Cadence is controlled by the workflow cron (.github/workflows/renovate.yaml),
  // NOT by a Renovate `schedule` field here. A config-level `schedule` that does not
  // overlap the cron firing window silently no-ops every run — a well-known
  // self-hosted footgun. The cron IS the schedule; keep it in one place.
  timezone: "America/Los_Angeles",

  dependencyDashboard: true,
  dependencyDashboardTitle: "🧟 Frankenbot — Dependency Dashboard",

  // Stable labels so the Phase 2 dispatcher can find Renovate PRs (label:frankenbot).
  labels: ["frankenbot", "dependencies", "renovate"],

  // Keep noise low and the tiny frank8s cluster calm while we're propose-only.
  // These also throttle the initial Phase 5 fan-out flood across the broadened
  // surfaces — raise them only once the agent triage loop keeps up.
  prConcurrentLimit: 3,
  prHourlyLimit: 2,

  // Worktrees live under .claude/worktrees/ (git worktrees, not the canonical tree).
  // They won't exist in CI's clean checkout, but ignore defensively so a local
  // Dockerfile duplicate can never become a second scanned surface.
  ignorePaths: ["**/node_modules/**", "**/bower_components/**", ".claude/**"],

  // --- Phase 5 surface scoping: MVP three + broadened fan-out surfaces ---
  // The MVP three (github-actions, pre-commit, dockerfile) plus terraform,
  // helm (helmv3 charts + helm-values images), and nuget. nuget is Renovate's
  // datasource for .NET; it covers .config/dotnet-tools.json natively. paket is
  // NOT a native manager, so it is handled via a customManager below (best-effort).
  // mise tool pins are likewise annotation-driven via a customManager.
  enabledManagers: [
    "github-actions",
    "pre-commit",
    "dockerfile",
    "terraform",
    "helmv3",
    "helm-values",
    "nuget",
  ],

  // pre-commit is opt-in in Renovate.
  "pre-commit": {
    enabled: true,
  },

  // --- customManagers: surfaces Renovate has no native manager for -----------
  customManagers: [
    // (a) mise tool pins — ANNOTATION-DRIVEN.
    //
    // Renovate cannot infer datasources for arbitrary `tool = "version"` lines in
    // a mise.toml, so this uses the standard `# renovate:` annotation convention:
    // a MAINTAINER adds a comment line directly above a tool pin they want tracked:
    //
    //     [tools]
    //     # renovate: datasource=github-releases depName=opentofu/opentofu
    //     opentofu = "1.9.0"
    //
    // The regex captures the datasource/depName (and optional versioning) from the
    // annotation, then the quoted version from the following `key = "value"` line.
    // Tool pins WITHOUT an annotation are intentionally ignored (opt-in per pin).
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)\\.?mise\\.toml$/"],
      matchStrings: [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s*\\n\\s*[A-Za-z0-9_.-]+\\s*=\\s*[\"'](?<currentValue>[^\"']+)[\"']",
      ],
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
    },
    // (b) paket dependencies — BEST-EFFORT.
    //
    // Renovate has no native paket manager. This captures the common pin forms in
    // a `paket.dependencies` file against the nuget datasource:
    //
    //     nuget FSharp.Core ~> 6.0
    //     nuget Newtonsoft.Json >= 13.0.1
    //
    // Best-effort only: exotic paket syntax (groups, framework restrictions,
    // strategy lines) is not covered. The native `nuget` manager already handles
    // .config/dotnet-tools.json; this fills the paket gap where possible.
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)paket\\.dependencies$/"],
      matchStrings: [
        "nuget\\s+(?<depName>\\S+)\\s+(?:~>|>=)\\s+(?<currentValue>[0-9][^\\s]*)",
      ],
      datasourceTemplate: "nuget",
    },
  ],

  packageRules: [
    // Group the mechanical, high-density surfaces into one PR each — less review churn.
    {
      matchManagers: ["github-actions"],
      groupName: "github-actions",
    },
    {
      matchManagers: ["pre-commit"],
      groupName: "pre-commit hooks",
    },
    // Phase 5 fan-out surfaces, grouped so the first flood is a handful of PRs.
    {
      matchManagers: ["terraform"],
      groupName: "terraform",
    },
    {
      matchManagers: ["helmv3", "helm-values"],
      groupName: "helm",
    },
    // nuget (native, incl. dotnet-tools) + the paket customManager → one dotnet group.
    {
      matchManagers: ["nuget"],
      matchDatasources: ["nuget"],
      groupName: "dotnet/nuget",
    },
    // Flag majors for human/agent attention. In the risk model a major bump is a
    // T3 candidate (human-required); the extra label makes those PRs filterable
    // before the Phase 4 classifier exists. Applies across ALL surfaces above.
    {
      matchUpdateTypes: ["major"],
      addLabels: ["major-update"],
    },
  ],
}
